# Local backend bootRun datasource (application.yml placeholders)
DB_HOST=jdbc:postgresql://localhost:5432/pgk_food
DB_USER=postgres
DB_PASS=change_me

# Docker Postgres container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pgk_food

# Docker app container profile and datasource override
SPRING_PROFILES_ACTIVE=it-postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/pgk_food
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change_me

# Security
JWT_SECRET=change_me_to_long_random_secret
JWT_LIFETIME=86400000

# Bootstrap admin (required for first login on clean DB)
APP_BOOTSTRAP_ADMIN_ENABLED=true
APP_TEST_MODE_ENABLED=false
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_PASSWORD=change_me_strong_password
BOOTSTRAP_ADMIN_NAME=System
BOOTSTRAP_ADMIN_SURNAME=Administrator
BOOTSTRAP_ADMIN_FATHER_NAME=Service
BOOTSTRAP_ADMIN_GROUP_NAME=101
